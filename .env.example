# Copy to .env and fill in. Read by both Prisma CLI and Next.js.
# In production, set these in the Netlify dashboard instead
# (DATABASE_URL is auto-set when you run `netlify db init`).

# Local: pooled + direct are the same DB.
# Prod (Netlify DB): DATABASE_URL=$NETLIFY_DATABASE_URL, DIRECT_URL=$NETLIFY_DATABASE_URL_UNPOOLED
DATABASE_URL="postgresql://USER@localhost:5432/dispatch"
DIRECT_URL="postgresql://USER@localhost:5432/dispatch"
ADMIN_PASSCODE="change-me"
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
